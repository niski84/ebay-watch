PORT=9109
EBAY_WATCH_DATA_DIR=data
POLL_INTERVAL_HOURS=4

# How long to allow Playwright to run per poll (SERP + item gallery pages).
# Increase if you have many searches or a slow connection.
PLAYWRIGHT_TIMEOUT_SECS=400
EBAY_PLAYWRIGHT_SCRIPT=scripts/ebay-search.mjs
NODE_BIN=node

# Set to 1 to skip opening each listing page for extra photos (faster polls, one image per item).
# EBAY_SKIP_ITEM_GALLERY=1

# Parallel tabs used when fetching item galleries (1–6, default 3).
# EBAY_ITEM_GALLERY_CONCURRENCY=3

# Extra pause (ms) if filmstrip thumbnails load slowly (default 700).
# EBAY_ITEM_GALLERY_SETTLE_MS=1200

# Show a real browser window for debugging bot-detection issues (local only).
# EBAY_PW_HEADLESS=0

# Optional HTTP Basic Auth. If unset, no authentication is required.
# HTTP_AUTH_USER=admin
# HTTP_AUTH_PASS=changeme
# Or multiple users (comma-separated user:pass pairs):
# HTTP_AUTH_USERS=alice:secret1,bob:secret2
