PORT=9109
EBAY_WATCH_DATA_DIR=data
POLL_INTERVAL_HOURS=4

# Same optional browser cache as plex-dashboard demo (see package.json "demo" script there):
# PLAYWRIGHT_BROWSERS_PATH=/home/nick/.cache/ms-playwright

# Item-page gallery enrichment needs headroom (many /itm/ loads per poll).
PLAYWRIGHT_TIMEOUT_SECS=400
EBAY_PLAYWRIGHT_SCRIPT=scripts/ebay-search.mjs
NODE_BIN=node

# Set to 1 to skip opening each listing page for extra photos (faster poll, grid lightbox = 1 image).
# EBAY_SKIP_ITEM_GALLERY=1
# Parallel tabs for gallery fetch (1–6, default 3).
# EBAY_ITEM_GALLERY_CONCURRENCY=3
# Longer pause if filmstrip thumbnails load slowly (default 700).
# EBAY_ITEM_GALLERY_SETTLE_MS=1200

# Headed Chromium sometimes avoids eBay interstitials (local desktop only).
# EBAY_PW_HEADLESS=0
